{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "选择你新建的 InfluxDB (Flux) 数据源",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["dex", "blockchain"],
  "templating": {
    "list": [
      {
        "name": "bucket",
        "label": "Bucket (链)",
        "type": "custom",
        "query": "ethereum,bsc,solana,sui",
        "current": { "text": "ethereum", "value": "ethereum" },
        "options": [
          { "text": "ethereum", "value": "ethereum", "selected": true },
          { "text": "bsc", "value": "bsc", "selected": false },
          { "text": "solana", "value": "solana", "selected": false },
          { "text": "sui", "value": "sui", "selected": false }
        ],
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DEX 解析监控 (Chain Parse Service)",
  "uid": "dex-parse-monitor",
  "version": 2,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Swap 总数",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"dex_transactions\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> group()\n  |> count()"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "交易额合计 (value 字段)",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"dex_transactions\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> group()\n  |> sum()"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "建池数 (dex_pools)",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"dex_pools\")\n  |> filter(fn: (r) => r._field == \"fee\")\n  |> group(columns: [\"addr\"])\n  |> last()\n  |> group()\n  |> count()"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "流动性事件数 (dex_liquidities)",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"dex_liquidities\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> group()\n  |> count()"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "每小时 Swap 笔数",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 50 }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "showLegend": false }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"dex_transactions\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> group()\n  |> aggregateWindow(every: 1h, fn: count, createEmpty: false)\n  |> yield(name: \"swaps\")"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "每小时交易额 (value 合计)",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth" }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "showLegend": false }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"dex_transactions\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> group()\n  |> aggregateWindow(every: 1h, fn: sum, createEmpty: false)\n  |> yield(name: \"volume\")"
        }
      ]
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "买 / 卖分布 (side)",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "pieType": "donut", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"dex_transactions\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> group(columns: [\"side\"])\n  |> count()\n  |> keep(columns: [\"side\", \"_value\"])"
        }
      ]
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "协议分布 (来自 dex_pools.protocol)",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "pieType": "pie", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"dex_pools\")\n  |> filter(fn: (r) => r._field == \"fee\")\n  |> group(columns: [\"addr\", \"protocol\"])\n  |> last()\n  |> group(columns: [\"protocol\"])\n  |> count()\n  |> keep(columns: [\"protocol\", \"_value\"])"
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Top 10 活跃池子 (按 Swap 数)",
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"dex_transactions\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> group(columns: [\"pool\"])\n  |> count()\n  |> group()\n  |> sort(columns: [\"_value\"], desc: true)\n  |> limit(n: 10)\n  |> keep(columns: [\"pool\", \"_value\"])\n  |> rename(columns: {_value: \"swaps\"})"
        }
      ]
    }
  ]
}
