# Chain Parse Service - Docker Environment Variables

# Parser chain type (sui, ethereum, bsc, solana)
CHAIN_TYPE=bsc

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432

# MySQL
MYSQL_ROOT_PASSWORD=password
MYSQL_PASSWORD=parser_pass
MYSQL_PORT=3306

# Redis
REDIS_PORT=6379

# InfluxDB
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=admin123456
INFLUXDB_ORG=unified-tx-parser
INFLUXDB_BUCKET=blockchain-data
INFLUXDB_RETENTION=90d
INFLUXDB_TOKEN=unified-tx-parser-token-2024
INFLUXDB_PORT=8086

# Grafana
GRAFANA_PORT=3000

# API
API_PORT=8081
